# ===========================================
# Variáveis de Ambiente - Portfólio
# ===========================================
# Copie este arquivo para .env e preencha os valores
# No Railway, configure essas variáveis em Settings > Variables

# ---- Database (PostgreSQL) ----
# Local: postgresql://postgres:SENHA@localhost:5432/portifolio?schema=public
# Railway: Será fornecida automaticamente ao adicionar o plugin PostgreSQL
DATABASE_URL="postgresql://postgres:SENHA@localhost:5432/portifolio?schema=public"

# ---- Admin (Credenciais do Painel Administrativo) ----
ADMIN_EMAIL=seu-email@gmail.com
ADMIN_PASSWORD=sua-senha-segura

# ---- Sessão (JWT Secret - mínimo 64 caracteres) ----
# Gere um novo com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=seu-secret-aqui-minimo-64-caracteres
